# ---- Site branding ----
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
NEXT_PUBLIC_SITE_TITLE=My Church Sermon Transcripts
NEXT_PUBLIC_CHURCH_NAME=My Church

# ---- Upload page password ----
UPLOAD_PASSWORD=changeme

# ---- Google Cloud ----
# For local dev, point to your service account key file:
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json
# For production (e.g. Vercel), use ONE of these:
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# GOOGLE_CREDENTIALS_BASE64=<base64-encoded service account JSON>

# Google Cloud project ID (required for Speech-to-Text V2 API)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud Storage bucket (must already exist)
GCS_BUCKET_NAME=your-sermons-bucket

# ---- GitHub ---- (for committing sermon JSON on transcription complete)
# Create a fine-grained PAT with Contents read/write on this repo
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=your-org/your-sermon-transcripts-repo

# ---- OpenAI ---- (for Whisper transcription + embeddings)
OPENAI_API_KEY=sk-...

# ---- AI models ----
WHISPER_MODEL=whisper-1
EMBEDDING_MODEL=text-embedding-3-small
AI_SEARCH_MODEL_ANTHROPIC=claude-haiku-4-5
AI_SEARCH_MODEL_DEEPSEEK=deepseek-chat
AI_SEARCH_MODEL_OPENAI=gpt-5.2
AI_SEARCH_MODEL_XAI=grok-4-fast-non-reasoning
AI_RETRIEVAL_PROVIDER=anthropic          # which provider runs agentic retrieval (anthropic|openai|deepseek|xai)

# ---- Anthropic ---- (for AI search - Claude)
ANTHROPIC_API_KEY=sk-ant-...

# ---- DeepSeek ---- (for AI search - DeepSeek, optional)
DEEPSEEK_API_KEY=sk-...

# ---- xAI ---- (for AI search - Grok, optional)
XAI_API_KEY=xai-...

# ---- Supabase ---- (for AI search vector store)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- SermonAudio ---- (optional, for importing existing sermons)
# SERMONAUDIO_API_KEY=...
# SERMONAUDIO_BROADCASTER_ID=...

# ---- Vercel ---- (optional)
# VERCEL_TOKEN=...
